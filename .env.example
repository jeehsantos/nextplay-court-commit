# Supabase Configuration
# Get these values from your Supabase project settings
VITE_SUPABASE_PROJECT_ID=your_project_id_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co

# Error Tracking (Optional - Sentry)
# Sign up at https://sentry.io and create a project
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Note: The publishable key is safe to expose in client-side code
# Never commit the actual .env file to version control

# Demo Mode — set to "true" to render static mock data on the main player &
# manager pages (Courts, Groups, Quick Challenges, My Bookings, Manager
# Dashboard, Manager Bookings, Manager Venues). Auth and mutations are NOT
# bypassed. Use for marketing demo recordings.
VITE_DEMO_MODE=false
